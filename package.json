{
  "name": "proyecto-inventario-pedidos",
  "private": true,
  "scripts": {
    "dev:db": "docker compose up -d mysql",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:all": "npm run dev:db && concurrently -k -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm run build --prefix frontend",
    "stop:db": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
